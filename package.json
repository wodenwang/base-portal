{
  "name": "base-portal",
  "version": "0.1.2",
  "private": true,
  "description": "Enterprise portal application integrated with Feishu IAM",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @base-portal/api --filter @base-portal/portal-web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "db:migrate": "pnpm --filter @base-portal/api prisma:migrate",
    "db:seed": "pnpm --filter @base-portal/api prisma:seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
